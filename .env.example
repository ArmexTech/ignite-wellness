# IGNITE — environment variables
# Values shown are set on Railway via dashboard; this file is only documentation.

# Required
DATABASE_URL="${{Postgres.DATABASE_URL}}"   # Auto-wired from Railway Postgres reference
JWT_SECRET="generate-with-crypto.randomBytes(48).toString('base64')"
APP_URL="https://ignite-wellness-production.up.railway.app"
NODE_ENV="production"
COOKIE_SECURE="true"
SESSION_DURATION_DAYS="30"

# Stripe (Phase 3) — add to enable payments
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."   # From Stripe Webhooks dashboard
# STRIPE_PRICE_1M="price_..."
# STRIPE_PRICE_3M="price_..."
# STRIPE_PRICE_12M="price_..."

# Resend (Phase 4) — add to enable email
# RESEND_API_KEY="re_..."
# EMAIL_FROM="IGNITE <hello@your-domain.com>"

# Web Push (Phase 5) — add to enable push notifications
# VAPID_PUBLIC_KEY="..."
# VAPID_PRIVATE_KEY="..."
# VAPID_SUBJECT="mailto:ops@your-domain.com"
